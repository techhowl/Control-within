# ============================================================================
# Control Within — environment variables
# ----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values. `.env.local` is
# gitignored; this template (.env.example) is committed.
# ============================================================================

# --- Supabase (required for the journey backend) ---------------------------
# Project Settings -> Data API -> Project URL (base URL, NO /rest/v1/ suffix)
SUPABASE_URL=
# Project Settings -> API Keys -> service_role (SECRET — server only, bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=

# --- WhatsApp handoff (required for /api/whatsapp/handoff) ------------------
# Business number in international format, digits only, no + or spaces.
# Example for India: 919999999999
WHATSAPP_NUMBER=

# --- Phase 2: Interakt (WhatsApp) — leave blank until you have an account ---
# Inbound webhooks require an Interakt Advanced/Enterprise plan.
INTERAKT_API_KEY=
INTERAKT_WEBHOOK_SECRET=
# Approved WhatsApp template used by /api/appointment-notify (body placeholders
# {{1}}=appointment_id, {{2}}=name, {{3}}=gender, {{4}}=age,
# {{5}}=contact/mobile, {{6}}="city - pincode" (combined).
INTERAKT_DOCTOR_TEMPLATE=patient_appointment
INTERAKT_TEMPLATE_LANG=en

# --- Phase 2: Zoho CRM — leave blank until field mapping is decided ---------
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_API_DOMAIN=
# OAuth token host (default https://accounts.zoho.in for the India DC).
ZOHO_ACCOUNTS_DOMAIN=
# Custom module for anonymous doctor-locator records.
ZOHO_LOCATOR_MODULE=Doctor_Locators
# Standard Leads module for paid/QR attribution leads. Requires custom fields
# Chat_ID, UTM_Source, UTM_Medium, UTM_Campaign, UTM_Content, UTM_Term,
# Placement, Platform, Src; Company must be non-mandatory in the Leads layout.
ZOHO_LEADS_MODULE=Leads
