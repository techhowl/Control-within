# ============================================================================
# Control Within — environment variables
# ----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values. `.env.local` is
# gitignored; this template (.env.example) is committed.
# ============================================================================

# --- Supabase (required for the journey backend) ---------------------------
# Project Settings -> Data API -> Project URL (base URL, NO /rest/v1/ suffix)
SUPABASE_URL=
# Project Settings -> API Keys -> service_role (SECRET — server only, bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=

# --- WhatsApp handoff (required for /api/whatsapp/handoff) ------------------
# Business number in international format, digits only, no + or spaces.
# Example for India: 919999999999
WHATSAPP_NUMBER=

# --- Phase 2: Interakt (WhatsApp) — leave blank until you have an account ---
# Inbound webhooks require an Interakt Advanced/Enterprise plan.
INTERAKT_API_KEY=
INTERAKT_WEBHOOK_SECRET=

# --- Phase 2: Zoho CRM — leave blank until field mapping is decided ---------
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_API_DOMAIN=
